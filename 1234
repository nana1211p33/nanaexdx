let currentRotation = 0;
let loadedImages = [];

function showStartupQuote() {
    const sq = quotes["起動時"];
    const q = sq[Math.floor(Math.random() * sq.length)];
    document.getElementById("startup-text").textContent = q.text;
    document.getElementById("startup-author").textContent = "　— " + q.author;
}

function loadImages() {
    loadedImages = [];
    let loadCount = 0;
    imageFiles.forEach((file, index) => {
        if (file) {
            const img = new Image();
            img.onload = () => { loadCount++; if (loadCount === imageFiles.filter(f=>f).length) drawRoulette(); };
            img.onerror = () => { loadCount++; if (loadCount === imageFiles.filter(f=>f).length) drawRoulette(); };
            img.src = file;
            loadedImages[index] = img;
        } else { loadedImages[index] = null; }
    });
    if (imageFiles.filter(f=>f).length === 0) drawRoulette();
}

video.volume = volumeSlider.value;
volumeSlider.addEventListener("input", e => { video.volume = e.target.value; omiVideo.volume = e.target.value; });

function drawRoulette() {
    const arc = Math.PI * 2 / items.length;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    items.forEach((item, i) => {
        const angle = i * arc;

        // セグメント
        ctx.beginPath();
        ctx.fillStyle = colors[i] || "#8b0000";
        ctx.moveTo(250, 250);
        ctx.arc(250, 250, 250, angle, angle + arc);
        ctx.fill();

        // 金色の境界線
        ctx.beginPath();
        ctx.strokeStyle = "rgba(200,150,12,0.6)";
        ctx.lineWidth = 2;
        ctx.moveTo(250, 250);
        ctx.lineTo(250 + 250 * Math.cos(angle), 250 + 250 * Math.sin(angle));
        ctx.stroke();

        // 人物画像
        if (loadedImages[i] && loadedImages[i].complete && loadedImages[i].width > 0) {
            ctx.save();
            ctx.translate(250, 250);
            ctx.rotate(angle + arc / 2);
            ctx.beginPath();
            ctx.arc(130, 0, 50, 0, Math.PI * 2);
            ctx.clip();
            ctx.drawImage(loadedImages[i], 80, -50, 100, 100);
            ctx.restore();
        }

        // 名前テキスト（旧字体・金色）
        ctx.save();
        ctx.translate(250, 250);
        ctx.rotate(angle + arc / 2);
        ctx.textAlign = "right";
        ctx.fillStyle = "#c8960c";
        ctx.font = "bold 18px 'Hiragino Mincho ProN', 'Yu Mincho', serif";
        ctx.strokeStyle = "#1a0000";
        ctx.lineWidth = 4;
        ctx.strokeText(item, 228, 8);
        ctx.fillText(item, 228, 8);
        ctx.restore();
    });
}

btn.addEventListener("click", () => {
    btn.disabled = true;
    charImg.classList.add("is-spinning");
    document.getElementById("result-display").classList.remove("show");
    document.getElementById("explanation-display").classList.remove("show");
    video.currentTime = 0; video.muted = false;
    video.play().catch(console.error);
    currentRotation += 360 * 8 + Math.random() * 360;
    canvas.style.transform = `rotate(${currentRotation}deg)`;
    setTimeout(() => {
        btn.disabled = false;
        charImg.classList.remove("is-spinning");
        const segmentAngle = 360 / items.length;
        const adjustedAngle = (360 - (currentRotation % 360)) % 360;
        const winnerIndex = Math.floor(adjustedAngle / segmentAngle) % items.length;
        const winner = items[winnerIndex];
        const winnerQuotes = quotes[winner] || [{ text:`${winner}ガ選バレマシタ！`, author: winner, explanation:"此ノ人物ニハ解説ガ登録サレテヲリマセン。" }];
        const q = winnerQuotes[Math.floor(Math.random() * winnerQuotes.length)];
        document.getElementById("result-quote").textContent = `「${q.text}」`;
        document.getElementById("result-author").textContent = "― " + q.author;
        document.getElementById("result-display").classList.add("show");
        document.getElementById("explanation-title").textContent = "說　解　言　名";
        document.getElementById("explanation-content").textContent = q.explanation;
        document.getElementById("explanation-display").classList.add("show");
    }, spinDuration);
});

showStartupQuote();
loadImages();
renderItemList();

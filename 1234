<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>大日本帝國　英傑ルーレット</title>
<style>
:root {
    --red: #8b0000;
    --gold: #c8960c;
    --cream: #f5e6c8;
    --dark: #1a0800;
}

html, body {
    margin: 0; padding: 0;
    width: 100%; height: 100%;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--dark);
    font-family: 'Hiragino Mincho ProN', 'Yu Mincho', '游明朝', serif;
}

#bg-video {
    position: fixed; top: 0; left: 0;
    width: 100vw; height: 100vh;
    object-fit: cover; z-index: -1;
}

#omi-video {
    position: fixed; top: 0; left: 0;
    width: 100vw; height: 100vh;
    object-fit: cover; z-index: 9999;
    display: none;
}

/* ヘッダー：右→左スクロール（旧日本語横書き方向） */
.jp-header {
    position: fixed; top: 0; left: 0; width: 100%;
    background: linear-gradient(90deg, #4a0000, #7a0000, #9a0000, #7a0000, #4a0000);
    padding: 18px 0; z-index: 100; overflow: hidden;
    box-shadow: 0 5px 25px rgba(139,0,0,0.9);
    border-bottom: 4px solid var(--gold);
    direction: rtl; /* 右から左 */
}

.scrolling-text {
    display: flex;
    white-space: nowrap;
    animation: scroll-right 20s linear infinite; /* 右→左方向 */
    direction: ltr; /* テキスト内部はltrで表示 */
}

/* 旧日本語横書き：右から左へ流れる */
@keyframes scroll-right {
    0%   { transform: translateX(0); }
    100% { transform: translateX(50%); }
}

.scrolling-text span {
    font-size: 1.9rem; font-weight: bold;
    color: var(--gold);
    text-shadow: 2px 2px 8px rgba(0,0,0,0.9), 0 0 12px rgba(200,150,12,0.4);
    padding: 0 80px; letter-spacing: 6px;
    font-family: 'Hiragino Mincho ProN', serif;
    /* 旧字体横書き：unicode-bidi で右から左 */
    unicode-bidi: bidi-override;
    direction: rtl;
}

.header-buttons {
    position: fixed; top: 20px; right: 20px;
    display: flex; gap: 15px; z-index: 151;
}

.header-btn {
    background: rgba(120,0,0,0.92);
    color: var(--gold);
    border: 3px solid var(--gold);
    padding: 15px 20px; border-radius: 5px;
    cursor: pointer; font-size: 1.5rem;
    font-weight: bold; transition: all 0.3s;
    font-family: inherit;
}

.header-btn:hover {
    background: rgba(160,0,0,1);
    transform: scale(1.05);
    box-shadow: 0 0 15px rgba(200,150,12,0.5);
}

.hamburger-icon {
    width: 30px; height: 24px;
    display: flex; flex-direction: column;
    justify-content: space-between; cursor: pointer;
}

.hamburger-icon span {
    display: block; width: 100%; height: 3px;
    background: var(--gold); transition: all 0.3s ease; border-radius: 2px;
}

.hamburger-icon.active span:nth-child(1) { transform: translateY(10.5px) rotate(45deg); }
.hamburger-icon.active span:nth-child(2) { opacity: 0; }
.hamburger-icon.active span:nth-child(3) { transform: translateY(-10.5px) rotate(-45deg); }

.omi-btn {
    position: fixed; bottom: 20px; left: 20px;
    background: rgba(120,0,0,0.92);
    color: var(--gold); border: 3px solid var(--gold);
    padding: 15px 25px; border-radius: 5px;
    cursor: pointer; font-size: 1.3rem;
    font-weight: bold; transition: all 0.3s; z-index: 150;
    font-family: inherit;
}

.omi-btn:hover {
    background: rgba(160,0,0,1); transform: scale(1.05);
    box-shadow: 0 0 20px rgba(200,150,12,0.5);
}

/* メニュー・設定パネル：旧字体対応、右→左 */
.hamburger-menu {
    position: fixed; top: 0; right: 0;
    background: rgba(10,3,0,0.97);
    padding: 80px 30px 30px 30px;
    border-left: 3px solid var(--gold);
    width: 500px; height: 100vh;
    overflow-y: auto; z-index: 150;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
    direction: rtl; /* メニューも右→左 */
}

.hamburger-menu.show { transform: translateX(0); }

.menu-section {
    margin-bottom: 30px; padding-bottom: 20px;
    border-bottom: 2px solid var(--gold);
    text-align: right; /* 右揃え */
}

.menu-section:last-child { border-bottom: none; }

.menu-title {
    color: var(--gold); font-size: 1.5rem;
    font-weight: bold; margin-bottom: 15px;
    letter-spacing: 4px;
}

.menu-text { color: var(--cream); font-size: 1rem; line-height: 1.9; margin-bottom: 10px; }
.menu-label { color: var(--cream); font-size: 1rem; margin-bottom: 8px; display: block; text-align: right; }

.menu-input, .menu-textarea {
    width: 100%; padding: 12px; border-radius: 3px;
    border: 2px solid var(--gold);
    background: rgba(200,150,12,0.08);
    color: var(--cream); font-size: 1rem;
    margin-bottom: 10px; font-family: inherit;
    box-sizing: border-box;
    direction: rtl; text-align: right;
}

.menu-textarea { min-height: 120px; resize: vertical; }

.menu-btn {
    width: 100%; background: rgba(120,0,0,0.8);
    color: var(--gold); border: 2px solid var(--gold);
    padding: 12px; border-radius: 3px; cursor: pointer;
    font-weight: bold; font-size: 1.1rem; margin-top: 10px;
    font-family: inherit; letter-spacing: 3px;
}

.menu-btn:hover { background: rgba(160,0,0,1); }

.settings-panel {
    position: fixed; top: 0; right: 0;
    background: rgba(10,3,0,0.97);
    padding: 80px 30px 30px 30px;
    border-left: 3px solid var(--gold);
    width: 450px; height: 100vh;
    overflow-y: auto; z-index: 150;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
    direction: rtl;
}

.settings-panel.show { transform: translateX(0); }

.settings-section {
    margin-bottom: 25px; padding-bottom: 15px;
    border-bottom: 2px solid var(--gold);
    text-align: right;
}

.settings-section:last-child { border-bottom: none; }

.settings-title {
    color: var(--gold); font-size: 1.3rem;
    font-weight: bold; margin-bottom: 15px; letter-spacing: 3px;
}

.settings-label { color: var(--cream); font-size: 1rem; margin-bottom: 8px; display: block; text-align: right; }

.settings-input {
    width: 100%; padding: 10px; border-radius: 3px;
    border: 2px solid var(--gold);
    background: rgba(200,150,12,0.08);
    color: var(--cream); font-size: 1rem;
    margin-bottom: 10px; box-sizing: border-box;
    direction: ltr; /* スライダー・数値は左から右 */
}

.settings-file-label {
    display: block; background: rgba(120,0,0,0.8);
    color: var(--gold); padding: 10px; border-radius: 3px;
    text-align: center; cursor: pointer;
    border: 2px solid var(--gold);
    margin-bottom: 10px; font-weight: bold; letter-spacing: 2px;
}

.settings-file-label:hover { background: rgba(160,0,0,1); }
.settings-file-input { display: none; }

.item-list {
    max-height: 400px; overflow-y: auto;
    background: rgba(200,150,12,0.05);
    padding: 10px; border-radius: 3px; margin-bottom: 10px;
}

.item-entry {
    background: rgba(120,0,0,0.5); padding: 15px;
    margin-bottom: 10px; border-radius: 3px;
    border: 2px solid var(--gold);
    text-align: right;
}

.item-entry-header {
    display: flex; justify-content: space-between;
    align-items: center; margin-bottom: 10px;
    flex-direction: row-reverse; /* 右→左 */
}

.item-remove {
    background: #4a0000; color: var(--cream);
    border: none; padding: 5px 15px;
    border-radius: 3px; cursor: pointer; font-weight: bold;
}

.item-remove:hover { background: #8b0000; }

.color-picker-wrapper {
    display: flex; align-items: center;
    gap: 10px; margin-bottom: 10px;
    flex-direction: row-reverse;
}

.color-picker {
    width: 60px; height: 40px;
    border: 2px solid var(--gold); border-radius: 3px; cursor: pointer;
}

.add-item-btn, .reset-btn {
    width: 100%; background: rgba(120,0,0,0.8);
    color: var(--gold); border: 2px solid var(--gold);
    padding: 12px; border-radius: 3px; cursor: pointer;
    font-weight: bold; font-size: 1.1rem; margin-bottom: 10px;
    font-family: inherit; letter-spacing: 3px;
}

.add-item-btn:hover { background: rgba(160,0,0,1); }
.reset-btn { background: rgba(70,0,0,0.8); }
.reset-btn:hover { background: rgba(100,0,0,1); }

/* 起動時名言：縦書き */
.startup-quote {
    position: fixed; top: 0; left: 0;
    width: 100%; height: 100%;
    background: radial-gradient(ellipse at center, #1a0500 0%, #000 100%);
    z-index: 1000; display: flex;
    flex-direction: row; /* 縦書き複数列は横並び */
    align-items: center; justify-content: center;
    animation: fadeOut 5s forwards;
    gap: 40px;
}

.startup-quote::before {
    content: '☀';
    position: absolute; font-size: 18rem;
    color: rgba(200,150,12,0.05);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
}

@keyframes fadeOut {
    0%  { opacity: 1; }
    70% { opacity: 1; }
    100%{ opacity: 0; pointer-events: none; }
}

/* 縦書きテキスト */
.startup-quote-text {
    color: var(--gold); font-size: 2.5rem;
    font-weight: bold; text-align: center;
    text-shadow: 2px 2px 12px rgba(0,0,0,1), 0 0 35px rgba(200,150,12,0.3);
    line-height: 2; letter-spacing: 6px;
    position: relative; z-index: 1;
    /* 縦書き */
    writing-mode: vertical-rl;
    text-orientation: mixed;
    max-height: 70vh;
}

.startup-quote-author {
    color: var(--cream); font-size: 1.4rem;
    font-style: normal; letter-spacing: 4px;
    position: relative; z-index: 1;
    writing-mode: vertical-rl;
    text-orientation: mixed;
}

/* 結果表示：縦書き */
.result-display {
    position: fixed; top: 120px; left: 50%;
    transform: translateX(-50%);
    background: rgba(90,0,0,0.93);
    padding: 20px 30px; border-radius: 5px;
    border: 3px solid var(--gold);
    max-width: 90%; width: 620px;
    opacity: 0; transition: opacity 0.5s;
    z-index: 50; pointer-events: none;
    box-shadow: 0 0 35px rgba(200,150,12,0.25);
    /* 旧字体横書き：右→左 */
    direction: rtl;
}

.result-display.show { opacity: 1; }

.result-quote {
    color: var(--gold); font-size: 1.8rem;
    font-weight: bold; text-align: center;
    margin-bottom: 10px; line-height: 1.6; letter-spacing: 3px;
}

.result-author {
    color: var(--cream); font-size: 1.2rem;
    text-align: center; letter-spacing: 2px;
}

/* 解説：縦書き */
.explanation-display {
    position: fixed; top: 180px; right: 110px;
    background: rgba(70,0,0,0.88);
    padding: 20px 25px; border-radius: 5px;
    border: 3px solid var(--gold);
    width: 220px; /* 縦書きなので幅を狭く */
    max-height: calc(100vh - 200px); overflow-y: auto;
    opacity: 0; transition: opacity 0.5s;
    z-index: 50; pointer-events: none;
    box-shadow: 0 0 20px rgba(200,150,12,0.2);
}

.explanation-display.show { opacity: 1; }

.explanation-title {
    color: var(--gold); font-size: 1.1rem;
    font-weight: bold; margin-bottom: 15px;
    text-align: center; border-bottom: 2px solid var(--gold);
    padding-bottom: 10px; letter-spacing: 5px;
    writing-mode: horizontal-tb; /* タイトルは横書き */
}

/* 解説本文：縦書き */
.explanation-content {
    color: var(--cream); font-size: 1.0rem;
    line-height: 1.9;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    height: calc(100vh - 320px);
    overflow-y: auto;
    letter-spacing: 2px;
}

.roulette-container {
    position: relative; width: 500px; height: 500px;
    margin-top: 120px; z-index: 10;
}

.character-pointer {
    position: absolute; top: 50%; right: -280px;
    width: 500px; height: 500px;
    transform: translateY(-50%); z-index: 10;
    filter: drop-shadow(0 0 12px rgba(200,150,12,0.6));
    object-fit: contain;
}

@keyframes crazy-shake-right {
    0%  { transform: translateY(-50%) translate(0,0) rotate(0) scale(1); }
    25% { transform: translateY(-50%) translate(-10px,10px) rotate(-15deg) scale(1.1); }
    50% { transform: translateY(-50%) translate(10px,-10px) rotate(15deg) scale(0.9); }
    75% { transform: translateY(-50%) translate(-15px,-5px) rotate(-25deg) scale(1.2); }
    100%{ transform: translateY(-50%) translate(0,0) rotate(0) scale(1); }
}

.is-spinning { animation: crazy-shake-right 0.05s infinite; }

canvas {
    border-radius: 50%;
    border: 10px solid var(--gold);
    background: #1a0800;
    transition: transform 4s cubic-bezier(0.15,0,0.15,1);
    box-shadow: 0 0 35px rgba(200,150,12,0.4), 0 0 70px rgba(139,0,0,0.3);
}

.controls { margin-top: 30px; z-index: 10; }

#spin-btn {
    position: fixed; padding: 75px;
    top: 540px; right: 104px;
    font-size: 2rem; font-weight: bold;
    border-radius: 8px; border: 3px solid var(--gold);
    cursor: pointer;
    background: rgba(100,0,0,0.85);
    color: var(--gold);
    box-shadow: 0 4px 20px rgba(139,0,0,0.6);
    transition: all 0.3s ease;
    font-family: 'Hiragino Mincho ProN', serif;
    letter-spacing: 5px;
    /* 縦書きボタン */
    writing-mode: vertical-rl;
    text-orientation: mixed;
}

#spin-btn:hover {
    background: linear-gradient(135deg, #6a0000, #c8960c, #6a0000);
    color: #fff8e0;
    box-shadow: 0 0 30px rgba(200,150,12,0.9), 0 0 60px rgba(200,150,12,0.4);
    transform: scale(1.05);
    text-shadow: 0 0 12px rgba(255,255,255,0.7);
}

#spin-btn:active { transform: scale(0.95); }
#spin-btn:disabled { background: #2a1a00; box-shadow: none; cursor: not-allowed; color: #5a4a00; border-color: #3a2a00; }
#spin-btn:disabled:hover { background: #2a1a00; box-shadow: none; transform: scale(1); }

.volume-controls {
    position: fixed; bottom: 20px; right: 20px;
    background: rgba(8,2,0,0.88);
    padding: 20px; border-radius: 8px; color: var(--cream);
    display: flex; flex-direction: column; gap: 10px;
    z-index: 200; min-width: 60px; align-items: center;
    border: 1px solid rgba(200,150,12,0.35);
}

.volume-controls span { font-size: 1.2rem; font-weight: bold; color: var(--gold); letter-spacing: 3px; }

#volume-slider {
    width: 150px; height: 8px; cursor: pointer;
    -webkit-appearance: none; appearance: none;
    background: #3a1a00; border-radius: 5px; outline: none;
}

#volume-slider::-webkit-slider-thumb {
    -webkit-appearance: none; appearance: none;
    width: 25px; height: 25px; background: var(--gold);
    border-radius: 50%; cursor: pointer; border: 2px solid #fff;
}

.f9-hint {
    position: fixed; bottom: 20px; left: 50%;
    transform: translateX(-50%);
    background: rgba(8,2,0,0.75);
    color: var(--gold); border: 1px solid rgba(200,150,12,0.4);
    padding: 6px 16px; border-radius: 20px;
    font-size: 0.85rem; z-index: 100;
    pointer-events: none; opacity: 0.75;
    letter-spacing: 2px;
    direction: rtl; /* ヒントも右→左 */
}

@media (max-width: 1200px) {
    .explanation-display { width: 180px; right: 15px; }
    .settings-panel, .hamburger-menu { width: 350px; }
}

@media (max-width: 768px) {
    .header-buttons { top: 70px; right: 10px; gap: 10px; }
    .header-btn { padding: 10px 15px; font-size: 1.2rem; }
    .settings-panel, .hamburger-menu { width: 90%; }
    .roulette-container { width: 350px; height: 350px; margin-top: 100px; }
    canvas { width: 350px !important; height: 350px !important; }
    .character-pointer { right: -200px; width: 350px; height: 350px; }
    .scrolling-text span { font-size: 1.5rem; padding: 0 50px; }
    .startup-quote-text { font-size: 1.8rem; }
    .result-display { top: 100px; width: 90%; padding: 15px 20px; }
    .explanation-display { display: none; }
    .result-quote { font-size: 1rem; }
    #spin-btn { writing-mode: horizontal-tb; padding: 12px 40px; font-size: 1.2rem; }
    .omi-btn { bottom: 80px; left: 15px; padding: 12px 20px; font-size: 1.1rem; }
}
</style>
</head>

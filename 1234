function renderItemList() {
    const itemList = document.getElementById("item-list");
    itemList.innerHTML = '';
    items.forEach((item, index) => {
        const entry = document.createElement('div');
        entry.className = 'item-entry';
        entry.innerHTML = `
            <div class="item-entry-header">
                <span style="color:var(--gold);font-weight:bold;">${index + 1}. ${item}</span>
                <button class="item-remove" data-index="${index}">削除</button>
            </div>
            <label class="settings-label">名稱</label>
            <input type="text" class="settings-input" data-index="${index}" data-type="name" value="${item}" style="direction:ltr;text-align:left;">
            <label class="settings-label">色彩</label>
            <div class="color-picker-wrapper">
                <input type="color" class="color-picker" data-index="${index}" value="${colors[index]||'#8b0000'}">
                <span style="color:var(--cream);">${colors[index]||'#8b0000'}</span>
            </div>
            <label class="settings-file-label">畫像ヲ變更
                <input type="file" class="settings-file-input" data-index="${index}" accept="image/*">
            </label>`;
        itemList.appendChild(entry);
    });

    document.querySelectorAll('.item-remove').forEach(b => {
        b.addEventListener('click', (e) => {
            const i = parseInt(e.target.dataset.index);
            items.splice(i,1); colors.splice(i,1);
            imageFiles.splice(i,1); loadedImages.splice(i,1);
            renderItemList(); drawRoulette();
        });
    });
    document.querySelectorAll('input[data-type="name"]').forEach(input => {
        input.addEventListener('input', (e) => {
            items[parseInt(e.target.dataset.index)] = e.target.value; drawRoulette();
        });
    });
    document.querySelectorAll('.color-picker').forEach(picker => {
        picker.addEventListener('input', (e) => {
            const i = parseInt(e.target.dataset.index);
            colors[i] = e.target.value;
            e.target.nextElementSibling.textContent = e.target.value;
            drawRoulette();
        });
    });
    document.querySelectorAll('input[type="file"][data-index]').forEach(input => {
        input.addEventListener('change', (e) => {
            const i = parseInt(e.target.dataset.index);
            const file = e.target.files[0];
            if (file) {
                const img = new Image();
                img.onload = () => { loadedImages[i] = img; drawRoulette(); };
                img.src = URL.createObjectURL(file);
            }
        });
    });
}

document.getElementById("add-item-btn").addEventListener("click", () => {
    items.push(`項目${items.length+1}`);
